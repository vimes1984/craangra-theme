{
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#2d5a27",
					"name": "Forest Green"
				},
				{
					"slug": "secondary",
					"color": "#d4af37",
					"name": "Honey Gold"
				},
				{
					"slug": "background",
					"color": "#fcfbfa",
					"name": "Cream"
				},
				{
					"slug": "foreground",
					"color": "#222222",
					"name": "Charcoal"
				},
				{
					"slug": "accent",
					"color": "#c05a46",
					"name": "Terracotta"
				}
			]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"units": ["px", "em", "rem", "vh", "vw"],
			"customPadding": true,
			"customMargin": true
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Outfit\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
					"name": "Outfit",
					"slug": "outfit",
					"fontFace": [
						{
							"fontFamily": "Outfit",
							"fontWeight": "100 900",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/outfit-variable.woff2" ]
						}
					]
				},
				{
					"fontFamily": "\"Cardo\", Georgia, serif",
					"name": "Cardo",
					"slug": "cardo",
					"fontFace": [
						{
							"fontFamily": "Cardo",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/cardo-normal.woff2" ]
						},
						{
							"fontFamily": "Cardo",
							"fontWeight": "700",
							"fontStyle": "normal",
							"src": [ "file:./assets/fonts/cardo-bold.woff2" ]
						}
					]
				}
			]
		}
	},
	"styles": {
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"top": "0px",
				"bottom": "0px",
				"left": "0px",
				"right": "0px"
			},
			"margin": {
				"top": "0px",
				"bottom": "0px"
			}
		},
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--outfit)",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "underline"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cardo)",
					"fontWeight": "600"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--background)"
				},
				"border": {
					"radius": "4px"
				},
				"typography": {
					"fontWeight": "600",
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"textTransform": "uppercase"
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "page-home",
			"title": "Home Page Layout",
			"postTypes": ["page"]
		},
		{
			"name": "page-our-story",
			"title": "Our Story Layout",
			"postTypes": ["page"]
		},
		{
			"name": "page-contact",
			"title": "Contact Layout",
			"postTypes": ["page"]
		}
	]
}
